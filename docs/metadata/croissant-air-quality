{
  "@context": {
    "@vocab": "https://schema.org/",
    "cr": "http://mlcommons.org/croissant/"
  },
  "@type": "cr:Dataset",
  "name": "Urban Air Quality Dataset",
  "description": "Pollutant and weather features for ML classification.",
  "license": "https://creativecommons.org/licenses/by/4.0/",
  "distribution": [
    {
      "@type": "cr:FileObject",
      "name": "air_quality_dataset.csv",
      "encodingFormat": "text/csv"
    }
  ],
  "recordSet": [
    {
      "@type": "cr:RecordSet",
      "name": "air_quality_measurements",
      "field": [
        {
          "@type": "cr:Field",
          "name": "pm10",
          "dataType": "sc:Integer",
          "unitText": "microgram per cubic metre"
        },
        {
          "@type": "cr:Field",
          "name": "no2",
          "dataType": "sc:Integer",
          "unitText": "microgram per cubic metre"
        },
        {
          "@type": "cr:Field",
          "name": "o3",
          "dataType": "sc:Integer",
          "unitText": "microgram per cubic metre"
        },
        {
          "@type": "cr:Field",
          "name": "temperature",
          "dataType": "sc:Integer",
          "unitText": "degree Celsius"
        },
        {
          "@type": "cr:Field",
          "name": "humidity",
          "dataType": "sc:Integer",
          "unitText": "percent"
        },
        {
          "@type": "cr:Field",
          "name": "wind_speed",
          "dataType": "sc:Float",
          "unitText": "metre per second"
        }
      ]
    }
  ]
}
